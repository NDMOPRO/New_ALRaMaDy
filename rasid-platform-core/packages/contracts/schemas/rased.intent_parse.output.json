{
  "$id": "https://rased.local/schemas/rased.intent_parse.output.json",
  "type": "object",
  "required": [
    "request_id",
    "tool_id",
    "status",
    "refs"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "tool_id": {
      "const": "rased.intent_parse"
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "failed"
      ]
    },
    "refs": {
      "type": "object",
      "required": [
        "intent_manifest"
      ],
      "properties": {
        "intent_manifest": {
          "type": "object",
          "required": [
            "goal",
            "engine_targets",
            "exports",
            "controls",
            "risk_level"
          ],
          "properties": {
            "goal": {
              "type": "string"
            },
            "engine_targets": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "exports": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "controls": {
              "type": "object"
            },
            "risk_level": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high"
              ]
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "warnings": {
      "$ref": "common.json#/$defs/Warnings"
    }
  },
  "additionalProperties": false
}
