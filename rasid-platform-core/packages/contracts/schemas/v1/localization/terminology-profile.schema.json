{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rasid/schemas/v1/localization/terminology-profile.schema.json",
  "title": "TerminologyProfile",
  "type": "object",
  "required": ["schema_namespace", "schema_version", "terminology_profile_id", "profile_name", "scope", "source_locale", "target_locale"],
  "properties": {
    "schema_namespace": { "const": "rasid.shared.localization.v1" },
    "schema_version": { "const": "1.0.0" },
    "terminology_profile_id": { "type": "string" },
    "profile_name": { "type": "string" },
    "scope": { "enum": ["org", "workspace", "domain", "user", "artifact_override"] },
    "source_locale": { "type": "string" },
    "target_locale": { "type": "string" },
    "default_style": { "enum": ["executive", "formal", "technical"] },
    "rule_refs": { "type": "array", "items": { "type": "string" } },
    "protected_term_refs": { "type": "array", "items": { "type": "string" } },
    "non_translatable_term_refs": { "type": "array", "items": { "type": "string" } },
    "parent_profile_refs": { "type": "array", "items": { "type": "string" } },
    "brand_preset_ref": { "type": ["string", "null"] },
    "acronym_policy": { "enum": ["preserve", "expand_once", "localize_if_defined"] },
    "title_policy": { "enum": ["localize", "preserve", "conditional"] },
    "caption_policy": { "enum": ["localize", "preserve", "conditional"] }
  }
}
