{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rasid/schemas/v1/localization/localization-request.schema.json",
  "title": "LocalizationRequest",
  "type": "object",
  "required": [
    "schema_namespace",
    "schema_version",
    "localization_request_id",
    "capability_id",
    "mode",
    "status",
    "source_artifact_ref",
    "source_canonical_ref",
    "target_artifact_type",
    "target_locale",
    "localization_scope_ref",
    "localization_policy_ref",
    "terminology_profile_ref",
    "direction_transformation_plan_ref",
    "typography_refinement_plan_ref",
    "cultural_formatting_plan_ref",
    "requested_by",
    "requested_at"
  ],
  "properties": {
    "schema_namespace": { "const": "rasid.shared.localization.v1" },
    "schema_version": { "const": "1.0.0" },
    "localization_request_id": { "type": "string" },
    "capability_id": { "const": "arabic_localization_lct" },
    "mode": { "enum": ["easy", "advanced"] },
    "status": {
      "enum": ["requested", "language_detected", "planning", "preview_ready", "awaiting_approval", "approved", "applied", "degraded", "failed", "cancelled"]
    },
    "source_artifact_ref": { "type": "string" },
    "source_canonical_ref": { "type": "string" },
    "target_artifact_type": { "enum": ["report", "presentation", "dashboard", "spreadsheet"] },
    "target_artifact_ref": { "type": ["string", "null"] },
    "source_locale": { "type": ["string", "null"] },
    "target_locale": { "type": "string" },
    "source_language_detection": { "enum": ["auto_detect", "explicit", "mixed_bilingual"] },
    "localization_scope_ref": { "type": "string" },
    "localization_policy_ref": { "type": "string" },
    "terminology_profile_ref": { "type": "string" },
    "direction_transformation_plan_ref": { "type": "string" },
    "typography_refinement_plan_ref": { "type": "string" },
    "cultural_formatting_plan_ref": { "type": "string" },
    "preview_ref": { "type": ["string", "null"] },
    "quality_result_ref": { "type": ["string", "null"] },
    "localized_output_metadata_ref": { "type": ["string", "null"] },
    "requested_by": { "type": "string" },
    "requested_at": { "type": "string" },
    "approved_by": { "type": ["string", "null"] },
    "applied_at": { "type": ["string", "null"] }
  }
}
