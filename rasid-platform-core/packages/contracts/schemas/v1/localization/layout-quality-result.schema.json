{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rasid/schemas/v1/localization/layout-quality-result.schema.json",
  "title": "LayoutQualityResult",
  "type": "object",
  "required": ["schema_namespace", "schema_version", "layout_quality_result_id", "request_ref", "status", "score"],
  "properties": {
    "schema_namespace": { "const": "rasid.shared.localization.v1" },
    "schema_version": { "const": "1.0.0" },
    "layout_quality_result_id": { "type": "string" },
    "request_ref": { "type": "string" },
    "status": { "enum": ["passed", "passed_with_warnings", "failed"] },
    "score": { "type": "number", "minimum": 0, "maximum": 100 },
    "clipping_refs": { "type": "array", "items": { "type": "string" } },
    "overflow_refs": { "type": "array", "items": { "type": "string" } },
    "alignment_issue_refs": { "type": "array", "items": { "type": "string" } },
    "hierarchy_issue_refs": { "type": "array", "items": { "type": "string" } },
    "mixed_direction_issue_refs": { "type": "array", "items": { "type": "string" } },
    "warning_count": { "type": "integer", "minimum": 0 }
  }
}
