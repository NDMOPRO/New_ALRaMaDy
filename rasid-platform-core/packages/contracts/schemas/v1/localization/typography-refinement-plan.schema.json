{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rasid/schemas/v1/localization/typography-refinement-plan.schema.json",
  "title": "TypographyRefinementPlan",
  "type": "object",
  "required": ["schema_namespace", "schema_version", "typography_refinement_plan_id", "request_ref"],
  "properties": {
    "schema_namespace": { "const": "rasid.shared.localization.v1" },
    "schema_version": { "const": "1.0.0" },
    "typography_refinement_plan_id": { "type": "string" },
    "request_ref": { "type": "string" },
    "target_node_refs": { "type": "array", "items": { "type": "string" } },
    "font_family_priority_refs": { "type": "array", "items": { "type": "string" } },
    "fallback_font_refs": { "type": "array", "items": { "type": "string" } },
    "line_height_strategy": { "enum": ["preserve", "expand_for_arabic", "compress_for_english", "adaptive"] },
    "baseline_mixing_strategy": { "enum": ["preserve", "align_to_arabic", "align_to_latin", "adaptive"] },
    "numeric_shaping_policy": { "enum": ["preserve_source", "arabic_indic", "latin", "context_aware"] },
    "clipping_repair_strategy": { "enum": ["none", "reflow", "resize", "manual"] },
    "preserve_brand_typography": { "type": "boolean" },
    "manual_review_required": { "type": "boolean" }
  }
}
