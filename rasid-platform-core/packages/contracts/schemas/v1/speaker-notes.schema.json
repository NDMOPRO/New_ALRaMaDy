{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rasid/schemas/v1/speaker-notes.schema.json",
  "title": "SpeakerNotes",
  "type": "object",
  "required": ["schema_namespace", "schema_version", "speaker_notes_id", "deck_ref", "version_ref", "slide_ref", "format"],
  "properties": {
    "schema_namespace": { "const": "rasid.shared.presentations.v1" },
    "schema_version": { "const": "1.0.0" },
    "speaker_notes_id": { "type": "string" },
    "deck_ref": { "type": "string" },
    "version_ref": { "type": "string" },
    "slide_ref": { "type": "string" },
    "format": { "enum": ["plain_text", "structured_brief", "presenter_cues"] }
  }
}
