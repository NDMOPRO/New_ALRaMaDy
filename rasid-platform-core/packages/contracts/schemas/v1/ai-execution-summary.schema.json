{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rasid/schemas/v1/ai-execution-summary.schema.json",
  "title": "AiExecutionSummary",
  "type": "object",
  "required": [
    "schema_namespace",
    "schema_version",
    "summary_id",
    "plan_ref",
    "job_ref",
    "outcome",
    "degrade_classification",
    "fallback_used",
    "approval_state",
    "selected_capability",
    "selected_action_ref",
    "selected_tool_ref",
    "selected_engine_ref",
    "selected_provider_ref",
    "selected_model_ref",
    "execution_step_details",
    "failure_summaries",
    "fallback_reason",
    "summary_text",
    "evidence_refs",
    "audit_refs",
    "lineage_refs",
    "result_artifact_refs",
    "suggestions",
    "next_action_suggestions",
    "generated_at"
  ],
  "properties": {
    "schema_namespace": { "const": "rasid.shared.ai.v1" },
    "schema_version": { "const": "1.0.0" },
    "summary_id": { "type": "string" },
    "plan_ref": { "type": "string" },
    "job_ref": { "type": "string" },
    "outcome": { "enum": ["success", "success_with_warnings", "degraded", "failed"] },
    "degrade_classification": { "type": ["string", "null"] },
    "fallback_used": { "type": "boolean" },
    "approval_state": { "enum": ["not_required", "pending", "approved", "rejected"] },
    "selected_capability": { "type": "string" },
    "selected_action_ref": { "type": ["string", "null"] },
    "selected_tool_ref": { "type": ["string", "null"] },
    "selected_engine_ref": { "type": ["string", "null"] },
    "selected_provider_ref": { "type": ["string", "null"] },
    "selected_model_ref": { "type": ["string", "null"] },
    "execution_step_details": { "type": "array", "items": { "type": "string" } },
    "failure_summaries": { "type": "array", "items": { "type": "string" } },
    "fallback_reason": { "type": ["string", "null"] },
    "summary_text": { "type": "string" },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "audit_refs": { "type": "array", "items": { "type": "string" } },
    "lineage_refs": { "type": "array", "items": { "type": "string" } },
    "result_artifact_refs": { "type": "array", "items": { "type": "string" } },
    "suggestions": { "type": "array", "items": { "type": "object" } },
    "next_action_suggestions": { "type": "array", "items": { "type": "string" } },
    "generated_at": { "type": "string" }
  }
}
