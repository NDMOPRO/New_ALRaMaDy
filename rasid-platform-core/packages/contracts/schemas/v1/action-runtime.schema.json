{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rasid/schemas/v1/action-runtime.schema.json",
  "title": "ActionDefinition",
  "type": "object",
  "required": ["action_id", "action_name", "capability", "input_schema", "output_schema", "approval_policy", "mutability"],
  "properties": {
    "action_id": { "type": "string" },
    "action_name": { "type": "string" },
    "capability": { "type": "string" },
    "approval_policy": { "enum": ["never", "conditional", "always"] },
    "mutability": { "enum": ["read_only", "mutating"] }
  }
}
