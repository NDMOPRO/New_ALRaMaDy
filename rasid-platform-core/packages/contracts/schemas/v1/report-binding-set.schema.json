{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rasid/schemas/v1/report-binding-set.schema.json",
  "title": "ReportBindingSet",
  "type": "object",
  "required": [
    "schema_namespace",
    "schema_version",
    "binding_set_id",
    "report_ref",
    "version_ref",
    "staleness_status",
    "refresh_policy"
  ],
  "properties": {
    "schema_namespace": { "const": "rasid.shared.report.v1" },
    "schema_version": { "const": "1.0.0" },
    "binding_set_id": { "type": "string" },
    "report_ref": { "type": "string" },
    "version_ref": { "type": "string" },
    "staleness_status": { "enum": ["live", "partially_live", "snapshot", "stale", "broken"] },
    "refresh_policy": { "type": "object" }
  }
}
