{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rasid/schemas/v1/transcription-bundle.schema.json",
  "title": "UnifiedContentBundle",
  "type": "object",
  "required": [
    "bundle_id",
    "capability_id",
    "tenant_ref",
    "workspace_id",
    "project_id",
    "artifact_ref",
    "canonical_ref",
    "source_refs",
    "sources",
    "segments",
    "aligned_words",
    "disagreements",
    "on_screen_text",
    "verification_gate",
    "fields",
    "entities",
    "summaries",
    "qa_seeds",
    "semantic_nodes",
    "semantic_edges"
  ],
  "properties": {
    "bundle_id": { "type": "string" },
    "capability_id": { "const": "transcription_extraction" },
    "tenant_ref": { "type": "string" },
    "workspace_id": { "type": "string" },
    "project_id": { "type": "string" },
    "artifact_ref": { "type": "string" },
    "canonical_ref": { "type": "string" },
    "source_refs": { "type": "array", "items": { "type": "string" } },
    "sources": { "type": "array", "items": { "type": "object" } },
    "segments": { "type": "array", "items": { "type": "object" } },
    "aligned_words": { "type": "array", "items": { "type": "object" } },
    "disagreements": { "type": "array", "items": { "type": "object" } },
    "on_screen_text": { "type": "array", "items": { "type": "object" } },
    "verification_gate": { "type": "object" },
    "fields": { "type": "array", "items": { "type": "object" } },
    "entities": { "type": "array", "items": { "type": "object" } },
    "summaries": { "type": "array", "items": { "type": "object" } },
    "qa_seeds": { "type": "array", "items": { "type": "object" } },
    "semantic_nodes": { "type": "array", "items": { "type": "object" } },
    "semantic_edges": { "type": "array", "items": { "type": "object" } }
  }
}
