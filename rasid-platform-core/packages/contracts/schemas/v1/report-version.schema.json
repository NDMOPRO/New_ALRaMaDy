{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rasid/schemas/v1/report-version.schema.json",
  "title": "ReportVersion",
  "type": "object",
  "required": [
    "schema_namespace",
    "schema_version",
    "report_version_id",
    "report_ref",
    "version_ref",
    "change_reason",
    "created_from",
    "draft_state"
  ],
  "properties": {
    "schema_namespace": { "const": "rasid.shared.report.v1" },
    "schema_version": { "const": "1.0.0" },
    "report_version_id": { "type": "string" },
    "report_ref": { "type": "string" },
    "version_ref": { "type": "object" },
    "change_reason": { "type": "string" },
    "created_from": {
      "enum": ["manual_edit", "dataset_refresh", "template_rebuild", "period_compare", "external_pattern_rebuild"]
    },
    "draft_state": { "enum": ["draft", "ready_for_review", "changes_requested", "finalized"] }
  }
}
