{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rasid/schemas/v1/report-approval-state.schema.json",
  "title": "ReportApprovalState",
  "type": "object",
  "required": ["schema_namespace", "schema_version", "approval_state_id", "report_ref", "version_ref", "state"],
  "properties": {
    "schema_namespace": { "const": "rasid.shared.report.v1" },
    "schema_version": { "const": "1.0.0" },
    "approval_state_id": { "type": "string" },
    "report_ref": { "type": "string" },
    "version_ref": { "type": "string" },
    "state": { "enum": ["not_required", "pending", "approved", "rejected"] }
  }
}
