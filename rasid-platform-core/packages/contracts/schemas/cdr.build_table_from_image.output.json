{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://strict.local/schemas/tools/cdr.build_table_from_image.output.json",
  "title": "cdr.build_table_from_image — Output",
  "description": "CDR data (table) built from image segments. Section 6 / B5.",
  "type": "object",
  "required": ["cdr_data", "warnings"],
  "properties": {
    "cdr_data": { "$ref": "../common.json#/$defs/CdrDataRef" },
    "row_count": { "type": "integer", "minimum": 0 },
    "column_count": { "type": "integer", "minimum": 0 },
    "merged_cell_count": { "type": "integer", "minimum": 0 },
    "warnings": { "$ref": "../common.json#/$defs/Warnings" }
  },
  "additionalProperties": false
}
