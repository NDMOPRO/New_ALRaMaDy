{
  "$id": "https://report.local/schemas/report.bind_data.output.json",
  "type": "object",
  "required": [
    "request_id",
    "tool_id",
    "status",
    "refs"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "tool_id": {
      "const": "report.bind_data"
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "failed"
      ]
    },
    "refs": {
      "type": "object",
      "required": [
        "doc",
        "doc_ir"
      ],
      "properties": {
        "doc": {
          "$ref": "common.json#/$defs/DocRef"
        },
        "doc_ir": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "warnings": {
      "$ref": "common.json#/$defs/Warnings"
    }
  },
  "additionalProperties": false
}
