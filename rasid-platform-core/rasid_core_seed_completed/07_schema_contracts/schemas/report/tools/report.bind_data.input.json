{
  "$id": "https://report.local/schemas/report.bind_data.input.json",
  "type": "object",
  "required": [
    "request_id",
    "tool_id",
    "context",
    "inputs",
    "params"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "tool_id": {
      "const": "report.bind_data"
    },
    "context": {
      "$ref": "common.json#/$defs/ActionContext"
    },
    "inputs": {
      "type": "object",
      "required": [
        "doc"
      ],
      "properties": {
        "doc": {
          "$ref": "common.json#/$defs/DocRef"
        },
        "datasets": {
          "type": "array",
          "items": {
            "$ref": "common.json#/$defs/DatasetRef"
          }
        },
        "tir_steps": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "mir_measures": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "additionalProperties": false
    },
    "params": {
      "type": "object",
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
