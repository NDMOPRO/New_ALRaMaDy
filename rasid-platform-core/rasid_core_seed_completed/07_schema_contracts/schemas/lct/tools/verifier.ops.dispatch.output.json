{
  "$id": "https://lct.local/schemas/verifier.ops.dispatch.output.json",
  "type": "object",
  "required": [
    "request_id",
    "tool_id",
    "status",
    "refs"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "tool_id": {
      "const": "verifier.ops.dispatch"
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "failed"
      ]
    },
    "refs": {
      "type": "object",
      "required": [
        "verified_transcript",
        "verifier_proof"
      ],
      "properties": {
        "verified_transcript": {
          "type": "object"
        },
        "verifier_proof": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "warnings": {
      "$ref": "common.json#/$defs/Warnings"
    }
  },
  "additionalProperties": false
}
