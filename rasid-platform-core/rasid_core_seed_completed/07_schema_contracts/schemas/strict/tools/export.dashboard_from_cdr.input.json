{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://strict.local/schemas/tools/export.dashboard_from_cdr.input.json",
  "title": "export.dashboard_from_cdr — Input",
  "description": "Exports a dashboard from a CDR design. Section 10 / B7.",
  "type": "object",
  "required": ["context", "cdr_design"],
  "properties": {
    "context": { "$ref": "../common.json#/$defs/ActionContext" },
    "cdr_design": { "$ref": "../common.json#/$defs/CdrDesignRef" },
    "font_plan": { "$ref": "../common.json#/$defs/FontPlan" },
    "options": {
      "type": "object",
      "properties": {
        "interactive": { "type": "boolean", "default": true },
        "responsive": { "type": "boolean", "default": true },
        "theme": { "type": "string", "enum": ["light", "dark", "auto"], "default": "auto" },
        "rtl_layout": { "type": "boolean", "default": true }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
