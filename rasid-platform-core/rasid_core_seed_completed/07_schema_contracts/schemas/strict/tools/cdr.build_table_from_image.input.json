{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://strict.local/schemas/tools/cdr.build_table_from_image.input.json",
  "title": "cdr.build_table_from_image — Input",
  "description": "Builds a CDR data (table) from image segments containing tables. Section 6 / B5.",
  "type": "object",
  "required": ["context", "segments", "source"],
  "properties": {
    "context": { "$ref": "../common.json#/$defs/ActionContext" },
    "segments": { "$ref": "../common.json#/$defs/ImageSegRef" },
    "source": { "$ref": "../common.json#/$defs/AssetRef" },
    "options": {
      "type": "object",
      "properties": {
        "detect_merged_cells": { "type": "boolean", "default": true },
        "detect_headers": { "type": "boolean", "default": true },
        "numeric_parsing": { "type": "boolean", "default": true }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
