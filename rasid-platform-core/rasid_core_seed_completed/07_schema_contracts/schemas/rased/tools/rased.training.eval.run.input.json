{
  "$id": "https://rased.local/schemas/rased.training.eval.run.input.json",
  "type": "object",
  "required": [
    "request_id",
    "tool_id",
    "context",
    "inputs",
    "params"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "tool_id": {
      "const": "rased.training.eval.run"
    },
    "context": {
      "$ref": "common.json#/$defs/ActionContext"
    },
    "inputs": {
      "type": "object",
      "required": [
        "suite_id"
      ],
      "properties": {
        "suite_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "params": {
      "type": "object",
      "required": [
        "must_pass"
      ],
      "properties": {
        "must_pass": {
          "type": "boolean",
          "const": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
