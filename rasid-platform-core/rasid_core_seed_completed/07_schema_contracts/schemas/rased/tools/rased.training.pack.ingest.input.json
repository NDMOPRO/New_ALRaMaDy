{
  "$id": "https://rased.local/schemas/rased.training.pack.ingest.input.json",
  "type": "object",
  "required": [
    "request_id",
    "tool_id",
    "context",
    "inputs",
    "params"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "tool_id": {
      "const": "rased.training.pack.ingest"
    },
    "context": {
      "$ref": "common.json#/$defs/ActionContext"
    },
    "inputs": {
      "type": "object",
      "required": [
        "pack_name",
        "assets"
      ],
      "properties": {
        "pack_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "assets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "common.json#/$defs/AssetRef"
          }
        }
      },
      "additionalProperties": false
    },
    "params": {
      "type": "object",
      "required": [
        "scope"
      ],
      "properties": {
        "scope": {
          "type": "string",
          "enum": [
            "user",
            "workspace",
            "org"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
