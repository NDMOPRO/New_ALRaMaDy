{
  "$id": "https://rased.local/schemas/rased.execute_action_graph.output.json",
  "type": "object",
  "required": [
    "request_id",
    "tool_id",
    "status",
    "refs"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "tool_id": {
      "const": "rased.execute_action_graph"
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "failed"
      ]
    },
    "refs": {
      "type": "object",
      "required": [
        "action_ids",
        "artifacts",
        "evidence_id"
      ],
      "properties": {
        "action_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "common.json#/$defs/ArtifactRef"
          }
        },
        "evidence_id": {
          "type": "string",
          "minLength": 8
        }
      },
      "additionalProperties": false
    },
    "warnings": {
      "$ref": "common.json#/$defs/Warnings"
    }
  },
  "additionalProperties": false
}
