{
  "$id": "https://rased.local/schemas/rased.ui_tour.step.output.json",
  "type": "object",
  "required": [
    "request_id",
    "tool_id",
    "status",
    "refs"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "tool_id": {
      "const": "rased.ui_tour.step"
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "failed"
      ]
    },
    "refs": {
      "type": "object",
      "required": [
        "acknowledged",
        "progress"
      ],
      "properties": {
        "acknowledged": {
          "type": "boolean"
        },
        "progress": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "warnings": {
      "$ref": "common.json#/$defs/Warnings"
    }
  },
  "additionalProperties": false
}
