{
  "$id": "https://rased.local/schemas/rased.knowledge.search.input.json",
  "type": "object",
  "required": [
    "request_id",
    "tool_id",
    "context",
    "inputs",
    "params"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "tool_id": {
      "const": "rased.knowledge.search"
    },
    "context": {
      "$ref": "common.json#/$defs/ActionContext"
    },
    "inputs": {
      "type": "object",
      "required": [
        "query"
      ],
      "properties": {
        "query": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "params": {
      "type": "object",
      "required": [
        "top_k"
      ],
      "properties": {
        "top_k": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
