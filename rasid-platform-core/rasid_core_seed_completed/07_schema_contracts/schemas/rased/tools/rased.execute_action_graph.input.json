{
  "$id": "https://rased.local/schemas/rased.execute_action_graph.input.json",
  "type": "object",
  "required": [
    "request_id",
    "tool_id",
    "context",
    "inputs",
    "params"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "tool_id": {
      "const": "rased.execute_action_graph"
    },
    "context": {
      "$ref": "common.json#/$defs/ActionContext"
    },
    "inputs": {
      "type": "object",
      "required": [
        "action_graph"
      ],
      "properties": {
        "action_graph": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "params": {
      "type": "object",
      "required": [
        "must_produce_evidence"
      ],
      "properties": {
        "must_produce_evidence": {
          "type": "boolean",
          "const": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
