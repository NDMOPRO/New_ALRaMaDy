{
  "$id": "https://rased.local/schemas/rased.intent_parse.input.json",
  "type": "object",
  "required": [
    "request_id",
    "tool_id",
    "context",
    "inputs",
    "params"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "tool_id": {
      "const": "rased.intent_parse"
    },
    "context": {
      "$ref": "common.json#/$defs/ActionContext"
    },
    "inputs": {
      "type": "object",
      "required": [
        "prompt"
      ],
      "properties": {
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "assets": {
          "type": "array",
          "items": {
            "$ref": "common.json#/$defs/AssetRef"
          }
        }
      },
      "additionalProperties": false
    },
    "params": {
      "type": "object",
      "properties": {
        "default_strict_claim": {
          "type": "string"
        },
        "default_exports": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
