{
  "$id": "https://rased.local/schemas/rased.explain.trace.input.json",
  "type": "object",
  "required": [
    "request_id",
    "tool_id",
    "context",
    "inputs",
    "params"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "tool_id": {
      "const": "rased.explain.trace"
    },
    "context": {
      "$ref": "common.json#/$defs/ActionContext"
    },
    "inputs": {
      "type": "object",
      "properties": {
        "action_graph": {
          "type": "object"
        },
        "execution": {
          "type": "object"
        },
        "evidence_id": {
          "type": "string",
          "minLength": 8
        }
      },
      "additionalProperties": false
    },
    "params": {
      "type": "object",
      "properties": {},
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
