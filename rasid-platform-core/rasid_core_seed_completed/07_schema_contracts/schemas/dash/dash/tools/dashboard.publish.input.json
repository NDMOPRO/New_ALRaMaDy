{
  "$id": "https://dash.local/schemas/dashboard.publish.input.json",
  "type": "object",
  "required": [
    "request_id",
    "tool_id",
    "context",
    "inputs",
    "params"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "tool_id": {
      "const": "dashboard.publish"
    },
    "context": {
      "$ref": "common.json#/$defs/ActionContext"
    },
    "inputs": {
      "type": "object",
      "required": [
        "dashboard",
        "share_policy",
        "permissions"
      ],
      "properties": {
        "dashboard": {
          "$ref": "common.json#/$defs/DashboardRef"
        },
        "share_policy": {
          "type": "object"
        },
        "permissions": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "params": {
      "type": "object",
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
