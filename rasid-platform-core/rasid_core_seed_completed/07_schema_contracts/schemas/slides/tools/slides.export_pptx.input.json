{
  "$id": "https://slides.local/schemas/slides.export_pptx.input.json",
  "type": "object",
  "required": ["request_id", "tool_id", "context", "inputs", "params"],
  "properties": {
    "request_id": { "type": "string" },
    "tool_id": { "const": "slides.export_pptx" },
    "context": { "$ref": "../common.json#/$defs/ActionContext" },
    "inputs": {
      "type": "object",
      "required": ["deck"],
      "properties": { "deck": { "$ref": "../common.json#/$defs/DeckRef" } },
      "additionalProperties": false
    },
    "params": {
      "type": "object",
      "required": ["embed_fonts"],
      "properties": { "embed_fonts": { "type": "boolean", "const": true } },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
