{
  "$id": "https://slides.local/schemas/slides.intent_parse.output.json",
  "type": "object",
  "required": ["request_id", "tool_id", "status", "refs"],
  "properties": {
    "request_id": { "type": "string" },
    "tool_id": { "const": "slides.intent_parse" },
    "status": { "type": "string", "enum": ["ok", "failed"] },
    "refs": {
      "type": "object",
      "required": ["intent"],
      "properties": {
        "intent": {
          "type": "object",
          "required": ["topic", "language", "slide_count", "tone", "density", "infographic_level", "motion_level"],
          "properties": {
            "topic": { "type": "string" },
            "language": { "type": "string", "enum": ["ar", "en", "mixed"] },
            "slide_count": { "type": "integer", "minimum": 1, "maximum": 200 },
            "tone": { "type": "string", "enum": ["formal", "neutral", "creative"] },
            "density": { "type": "string", "enum": ["sparse", "standard", "dense"] },
            "infographic_level": { "type": "string", "enum": ["low", "med", "high"] },
            "motion_level": { "type": "string", "enum": ["none", "basic", "cinematic"] },
            "must_include": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
