{
  "$id": "https://slides.local/schemas/slides.export_pptx.output.json",
  "type": "object",
  "required": ["request_id", "tool_id", "status", "refs"],
  "properties": {
    "request_id": { "type": "string" },
    "tool_id": { "const": "slides.export_pptx" },
    "status": { "type": "string", "enum": ["ok", "failed"] },
    "refs": {
      "type": "object",
      "required": ["pptx"],
      "properties": { "pptx": { "$ref": "../common.json#/$defs/ArtifactRef" } },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
