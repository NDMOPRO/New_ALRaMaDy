{
  "$id": "https://excel.local/schemas/recipe.apply.input.json",
  "type": "object",
  "required": [
    "request_id",
    "tool_id",
    "context",
    "inputs",
    "params"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "tool_id": {
      "const": "recipe.apply"
    },
    "context": {
      "$ref": "common.json#/$defs/ActionContext"
    },
    "inputs": {
      "type": "object",
      "required": [
        "recipe",
        "dataset"
      ],
      "properties": {
        "recipe": {
          "$ref": "common.json#/$defs/RecipeRef"
        },
        "dataset": {
          "$ref": "common.json#/$defs/DatasetRef"
        }
      },
      "additionalProperties": false
    },
    "params": {
      "type": "object",
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
