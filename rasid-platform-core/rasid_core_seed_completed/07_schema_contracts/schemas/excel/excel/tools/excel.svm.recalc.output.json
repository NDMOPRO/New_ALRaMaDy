{
  "$id": "https://excel.local/schemas/excel.svm.recalc.output.json",
  "type": "object",
  "required": [
    "request_id",
    "tool_id",
    "status",
    "refs"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "tool_id": {
      "const": "excel.svm.recalc"
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "failed"
      ]
    },
    "refs": {
      "type": "object",
      "required": [
        "artifact"
      ],
      "properties": {
        "artifact": {
          "$ref": "common.json#/$defs/ArtifactRef"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
