{
  "$id": "https://excel.local/schemas/catalog.unify_columns.input.json",
  "type": "object",
  "required": [
    "request_id",
    "tool_id",
    "context",
    "inputs",
    "params"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "tool_id": {
      "const": "catalog.unify_columns"
    },
    "context": {
      "$ref": "common.json#/$defs/ActionContext"
    },
    "inputs": {
      "type": "object",
      "required": [
        "columns"
      ],
      "properties": {
        "columns": {
          "type": "array",
          "items": {
            "$ref": "common.json#/$defs/ColumnRef"
          }
        }
      },
      "additionalProperties": false
    },
    "params": {
      "type": "object",
      "required": [
        "apply_mode"
      ],
      "properties": {
        "apply_mode": {
          "type": "string",
          "enum": [
            "smart_apply",
            "pro_suggest_only"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
